# Backend Database Configuration (used by Node.js application)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_360_eps_jorat
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Database Sync Mode (development only - use migrations in production)
# Options: 'force' (drops/recreates tables), 'alter' (modifies existing), 'none' (skip sync)
DB_SYNC_MODE=alter

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
CORS_ORIGIN=your_frontend_origin_here

# Environment (development, production, test)
NODE_ENV=development
